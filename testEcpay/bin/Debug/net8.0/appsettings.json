{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",

  // ── 資料庫（Neon PostgreSQL）─────────────────────────────────────────────
  // 從 Vercel Dashboard → Storage → 你的 DB → Connection String 取得
  // 格式：Host=xxx.neon.tech;Database=neondb;Username=xxx;Password=xxx;SSL Mode=Require
  "ConnectionStrings": {
    "DefaultConnection": "Host=YOUR_NEON_HOST.neon.tech;Database=neondb;Username=YOUR_USER;Password=YOUR_PASSWORD;SSL Mode=Require;Trust Server Certificate=true"
  },

  // ── JWT ──────────────────────────────────────────────────────────────────
  // Secret 請用隨機長字串（至少 32 字元）
  "Jwt": {
    "Secret": "YOUR_JWT_SECRET_AT_LEAST_32_CHARS_LONG",
    "Issuer": "magic-library-api",
    "Audience": "magic-library-frontend",
    "ExpiresInDays": 7
  },

  // ── 綠界 ECPay ────────────────────────────────────────────────────────────
  "ECPay": {
    "MerchantID": "YOUR_ECPAY_MERCHANT_ID",
    "HashKey": "YOUR_ECPAY_HASH_KEY",
    "HashIV": "YOUR_ECPAY_HASH_IV",
    "Environment": "Staging",
    "BaseUrl": "https://your-csharp-api.railway.app"
  },

  // ── CORS（允許的前端網址）────────────────────────────────────────────────
  "Cors": {
    "AllowedOrigins": [
      "http://localhost:3000",
      "https://your-nextjs-app.vercel.app"
    ]
  }
}
